# Patents MCP Server — Environment Variables
# Copy to .env and fill in your keys. Missing keys disable related tools gracefully.

# USPTO Open Data Portal (required for ODP, PTAB, citations, office actions)
# Get key at: https://data.uspto.gov/ → MyODP
USPTO_API_KEY=

# PatentsView (required for patent search, assignees, inventors, attorneys)
# Get key at: https://patentsview.org/apis/keyrequest
PATENTSVIEW_API_KEY=

# EPO OPS (required for international patent families, legal status)
# Register at: https://developers.epo.org/ → create app → get Consumer Key + Secret
EPO_CONSUMER_KEY=
EPO_CONSUMER_SECRET=

# Google BigQuery (required for full-text search across 90M+ patents)
# Create a GCP service account with bigquery.jobUser + bigquery.dataViewer roles
# Supports ~ and $HOME expansion when running locally
# For Docker: use absolute path (mounted as volume in docker-compose.yml)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

# Server configuration
TRANSPORT=stdio                   # stdio | httpStream
PORT=8080                         # For httpStream transport
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30000             # ms
MAX_RETRIES=3
RETRY_MIN_WAIT=2000               # ms
RETRY_MAX_WAIT=10000              # ms
