# USPTO Open Data Portal (required for ODP, PTAB, Office Actions, Litigation)
USPTO_API_KEY=

# PatentsView (optional — key grants suspended March 2026)
PATENTSVIEW_API_KEY=

# EPO OPS (required for EPO tools — register at developers.epo.org)
EPO_CONSUMER_KEY=
EPO_CONSUMER_SECRET=

# Google BigQuery (required for BigQuery tools)
GOOGLE_APPLICATION_CREDENTIALS=   # Path to service account JSON
GOOGLE_CLOUD_PROJECT=             # GCP project ID

# Server configuration
TRANSPORT=stdio                   # stdio | httpStream
PORT=8080                         # For httpStream transport
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30000             # ms
MAX_RETRIES=3
RETRY_MIN_WAIT=2000               # ms
RETRY_MAX_WAIT=10000              # ms
